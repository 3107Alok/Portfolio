---
import { Image } from "astro:assets";
import { Avatar_180 } from "@assets/images";

const { config } = Astro.props;
---

<section
    id="Hero"
    class="w-full h-[calc(100vh-4rem)] py-4 bg-background flex justify-evenly lg:justify-around items-center flex-col-reverse lg:flex-row overflow-hidden"
>
    <!-- Hero Intro Info -->
    <div class="w-full lg:w-fit flex justify-start items-center flex-col gap-8">
        <div class="text-[18px] lg:text-[26px] text-center lg:text-left">
            <div class="Fade_Stagger mb-6 flex justify-center lg:justify-start">
                <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-500/10 border border-green-500/25 rounded-full text-xs font-semibold text-green-400 tracking-wider uppercase shadow-[0_0_15px_rgba(34,197,94,0.1)]">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                    </span>
                    Open to Internships & Full-time Roles
                </span>
            </div>
            <p class="Fade_Stagger">{config.salutation}</p>
            <h1
                class="Fade_Stagger gradientText font-ubuntu text-[3.5em] lg:text-[6.5rem] leading-tight max-w-xs md:max-w-6xl"
            >
                {config.firstName}
                {" " + config.lastName}
            </h1>
            <p class="Fade_Stagger">I'm a {config.position}.</p>
            <p class="Fade_Stagger">
                {config.tagLine.prefixText}
                <span class="gradientText font-ubuntu">
                    {config.tagLine.highlightedText}
                </span>
                {config.tagLine.suffixText}
            </p>
        </div>

        <div
            class="Fade_Stagger flex justify-center lg:justify-start items-center w-full gap-10 py-4 text-socialIconColor!"
        >
            {
                config.links &&
                    config.links.map(
                        (link: {
                            label: string;
                            url: string;
                            icon: string;
                        }) => (
                            <a
                                href={link.url}
                                title={link.label}
                                aria-label={link.label}
                                target="_blank"
                                rel="noreferrer"
                                class="Fade_Stagger w-[30px] h-[30px] flex items-center justify-center"
                            >
                                <Fragment set:html={link.icon} />
                            </a>
                        ),
                    )
            }
        </div>
    </div>

    <!-- Hero Orbit Animation -->
    <div
        class="Hero_Orbit relative flex_center w-[340px] lg:w-[500px] aspect-square"
    >
        <div
            id="avatarImage"
            role="button"
            class="flex_center w-[180px] sm:w-[250px] aspect-square rounded-full z-10 cursor-pointer"
        >
            <Image
                src={Avatar_180}
                alt=`${config.firstName} ${config.lastName} Avatar`
                class="object-cover w-full h-full rounded-full noDrag"
                width="500"
                height="500"
                priority
            />
        </div>

        <!-- Orbit Trails -->
        <div class="Spring_Up Hero_Trail Trail1">
            <span class="Orbit_Dot"></span>
        </div>
        <div class="Spring_Up Hero_Trail Trail2">
            <span class="Orbit_Dot"></span>
        </div>
        <div class="Spring_Up Hero_Trail Trail3">
            <span class="Orbit_Dot"></span>
        </div>
        <div class="Spring_Up Hero_Trail Trail4">
            <span class="Orbit_Dot"></span>
        </div>
    </div>
</section>
