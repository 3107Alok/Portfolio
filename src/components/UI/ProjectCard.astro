---
import type { IProject } from "@/config/ProjectsList";
import { Image } from "astro:assets";

type Props = {
    project: IProject;
    className?: string;
};

const { project, className }: Props = Astro.props;

// PROJECT STATUS
const PROJECT_STATUS = project.status === "development" ? "BUILDING" : "COMPLETED";

// PLATFORM LABEL CHECK (App vs Web vs IoT)
const isApp = project.platform?.toLowerCase().includes("flutter") || 
              project.platform?.toLowerCase().includes("cross-platform") || 
              project.platform?.toLowerCase().includes("android") || 
              project.platform?.toLowerCase().includes("ios");
const isIoT = project.platform?.toLowerCase().includes("iot") || 
              project.platform?.toLowerCase().includes("raspberry") ||
              project.platform?.toLowerCase().includes("hardware");
const platformLabel = isIoT ? "AI/ML + IoT" : (isApp ? "App" : "Web");

// SERIALIZE PROJECT DATA FOR MODAL
const projectData = JSON.stringify({
    name: project.name,
    shortDescription: project.shortDescription,
    description: project.description,
    liveUrl: project.liveUrl,
    sourceUrl: project.sourceUrl,
    downloadUrl: project.downloadUrl || "",
    role: project.role || "Solo",
    duration: project.duration || "2 Months",
    platform: project.platform || "Web",
    status: PROJECT_STATUS,
    technologies: project.technologies.map(t => ({ title: t.title, icon: t.icon.src })),
    features: project.features.map(f => ({ title: f.title, description: f.description })),
    screenshots: project.screenshots ? project.screenshots.map(s => s.src) : [project.previewImage.src, project.deviceMockupImage.src],
    challenges: project.challenges || "",
    improvements: project.improvements || "",
    architecture: project.architecture || []
});
---

<div
    role="button"
    tabindex="0"
    class={`Project_Stagger Card_Main project-card-trigger w-full flex flex-col bg-footerAltLite/60 border border-white/10 hover:border-primary/30 rounded-2xl overflow-hidden mt-3 cursor-pointer transition-all duration-300 hover:shadow-[0_10px_30px_rgba(147,51,234,0.15)] hover:-translate-y-1.5 focus:outline-none focus:ring-2 focus:ring-primary/50 group select-none ${className}`}
    data-project={projectData}
>
    <!-- Image Wrapper with Zoom on Hover -->
    <div class="relative w-full aspect-[16/10] overflow-hidden bg-black/20 p-1 shrink-0">
        <Image
            class="w-full h-full object-cover rounded-xl transition-transform duration-500 ease-out group-hover:scale-105"
            src={project.previewImage}
            alt={`Screenshot of ${project.name}`}
            widths={[346, (project.previewImage as any).width]}
            sizes={`(max-width: 720px) 346px, ${(project.previewImage as any).width}px`}
            loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
            <span class="text-[9px] font-bold uppercase tracking-wider text-white bg-primary/80 px-2 py-0.5 rounded backdrop-blur-sm">
                Details
            </span>
        </div>
    </div>

    <!-- Details Container -->
    <div class="flex flex-col flex-1 p-4 md:p-5 space-y-3">
        <!-- Title & Status -->
        <div class="flex justify-between items-start gap-3">
            <div class="flex items-center gap-2 min-w-0">
                <Image
                    src={project.logoImage}
                    alt={`${project.name} Logo`}
                    width={32}
                    height={32}
                    loading="lazy"
                    class="h-8 w-8 object-contain shrink-0"
                />
                <h3 class="font-ubuntu text-base md:text-lg font-bold text-white group-hover:text-primary transition-colors line-clamp-1 min-w-0">
                    {project.name}
                </h3>
            </div>
            
            <div class="flex flex-col items-end gap-1.5 shrink-0">
                <span class="inline-flex items-center gap-1 text-[10px] md:text-xs font-semibold tracking-wider text-purple-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-purple-400/80 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {project.duration || "2 Months"}
                </span>

                <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-bold tracking-wider uppercase border bg-gradient-to-r transition-all duration-300 shadow-sm animate-pulse-subtle ${
                    isIoT
                        ? "bg-amber-500/10 border-amber-500/30 text-amber-400 shadow-amber-500/5"
                        : (isApp 
                            ? "bg-blue-500/10 border-blue-500/30 text-blue-400 shadow-blue-500/5" 
                            : "bg-emerald-500/10 border-emerald-500/30 text-emerald-400 shadow-emerald-500/5")
                }`}>
                    <span class={`w-1 h-1 rounded-full mr-1.5 ${
                        isIoT ? "bg-amber-400" : (isApp ? "bg-blue-400" : "bg-emerald-400")
                    }`}></span>
                    {platformLabel}
                </span>
            </div>
        </div>

        <!-- 2-Line Description (truncated) -->
        <p class="text-white/70 text-xs md:text-sm leading-relaxed line-clamp-2 flex-1">
            {project.shortDescription}
        </p>

        <!-- Tech Stack & View CTA -->
        <div class="flex justify-between items-center pt-3 border-t border-white/5">
            <!-- Tech badges (horizontal icons) -->
            <div class="flex gap-2.5 items-center overflow-hidden">
                {
                    project.technologies.slice(0, 5).map((tech) => (
                        <Image
                            src={tech.icon}
                            alt={tech.title}
                            title={tech.title}
                            width={16}
                            height={16}
                            loading="lazy"
                            class="opacity-60 hover:opacity-100 transition-opacity"
                        />
                    ))
                }
                {project.technologies.length > 5 && (
                    <span class="text-[10px] text-white/40 font-semibold bg-white/5 px-1.5 py-0.5 rounded">
                        +{project.technologies.length - 5}
                    </span>
                )}
            </div>

            <!-- View CTA -->
            <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary group-hover:text-primary/80 transition-colors">
                Details
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
            </span>
        </div>
    </div>
</div>

<style>
@keyframes pulse-subtle {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(0.97); }
}
.animate-pulse-subtle {
    animation: pulse-subtle 3s infinite ease-in-out;
}
</style>
