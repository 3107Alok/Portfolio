---
import { Layout } from '@layouts/index';
import { Hero, About, Skills, Projects, Certifications, Contact } from '@components/index';

const { themeConfig, siteConfig, headerConfig, heroConfig, aboutConfig, footerConfig } =
    await import('@/config/portfolio.config');
---

<Layout
    config={{
        theme: themeConfig,
        site: siteConfig,
        header: headerConfig,
        footer: footerConfig,
    }}
>
    <Hero config={heroConfig} />
    <About config={aboutConfig} />
    <Skills />
    <Projects />
    <Certifications />
    <Contact />
</Layout>
