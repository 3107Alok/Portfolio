---
import { CenterTitle } from "@components/UI";
import { Image } from "astro:assets";
import { CertificationsList } from "@/config/CertificationsList";

// Map issuer logos to SVGs or labels
const getCompanyBadgeClass = (company: string) => {
    switch (company) {
        case "aws":
            return "bg-amber-500/10 border-amber-500/30 text-amber-400";
        case "infosys":
            return "bg-blue-500/10 border-blue-500/30 text-blue-400";
        case "pearson":
            return "bg-emerald-500/10 border-emerald-500/30 text-emerald-400";
        default:
            return "bg-purple-500/10 border-purple-500/30 text-purple-400";
    }
};
---

<section id="certifications" class="w-full py-16 bg-background flex flex-col justify-center border-t border-white/5">
    <CenterTitle title="Certifications" color="primary" />

    <div class="max-w-[1300px] w-full mx-auto px-4 lg:px-8 mt-10">
        <!-- 3-Column Grid on Desktop, 2 on tablet, 1 on mobile for maximum clarity -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center">
            {
                CertificationsList.map((cert) => (
                    <div class="Fade_Up certificate-card w-full max-w-[380px] flex flex-col bg-footerAltLite/60 border border-white/10 hover:border-primary/30 rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-[0_10px_30px_rgba(147,51,234,0.12)] hover:-translate-y-1.5 group cursor-pointer">
                        
                        <!-- Mini Preview Image (Clickable Lightbox Trigger) -->
                        <div class="relative w-full aspect-[1.41/1] overflow-hidden bg-black/20 shrink-0 border-b border-white/5">
                            <Image
                                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-102 screenshot-preview-trigger"
                                src={cert.image}
                                alt={`Certificate for ${cert.title}`}
                                widths={[380]}
                                sizes="380px"
                                loading="lazy"
                            />
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center pointer-events-none">
                                <span class="text-xs font-semibold tracking-wider text-white bg-primary/95 px-3 py-1.5 rounded-lg backdrop-blur-sm shadow-md">
                                    Click to View Full Screen
                                </span>
                            </div>
                        </div>

                        <!-- Certificate Info -->
                        <div class="p-5 flex flex-col flex-1 gap-3.5 justify-between">
                            <div class="space-y-2">
                                <div class="flex items-center justify-between gap-2">
                                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border shadow-sm ${getCompanyBadgeClass(cert.companyLogo || "")}`}>
                                        {cert.issuer}
                                    </span>
                                    <span class="text-[10px] md:text-xs text-white/50 font-medium">
                                        {cert.date}
                                    </span>
                                </div>

                                <h3 class="text-white font-ubuntu font-bold text-sm md:text-base leading-snug tracking-wide group-hover:text-primary transition-colors duration-200 line-clamp-2">
                                    {cert.title}
                                </h3>
                                
                                {cert.credentialId && (
                                    <p class="text-[10px] text-white/40 font-mono tracking-tight truncate">
                                        ID: {cert.credentialId}
                                    </p>
                                )}
                            </div>

                            {cert.verificationUrl && (
                                <a
                                    href={cert.verificationUrl}
                                    target="_blank"
                                    rel="noreferrer"
                                    class="verify-link inline-flex items-center justify-center gap-1.5 w-full py-2 rounded-lg bg-white/5 hover:bg-white/10 text-white text-xs font-medium border border-white/10 hover:border-white/20 transition-all mt-2"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                    Verify Credential
                                </a>
                            )}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<script>
    // Listen for clicks on certificate cards to open fullscreen preview
    document.addEventListener("DOMContentLoaded", () => {
        const cards = document.querySelectorAll(".certificate-card");
        cards.forEach(card => {
            card.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;
                // If clicked element is a link or inside a link, don't open preview
                if (target.closest("a")) return;
                
                const img = card.querySelector(".screenshot-preview-trigger") as HTMLImageElement | null;
                if (img) {
                    img.click(); // Bubbles up and triggers the script.ts fullscreen viewer
                }
            });
        });
    });
</script>
